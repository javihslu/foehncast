project_id                     = "your-gcp-project"
region                         = "europe-west6"
artifact_registry_repository_id = "foehncast-docker"
artifact_bucket_name           = "foehncast-artifacts-your-gcp-project"
bigquery_dataset_id            = "foehncast"
bigquery_location              = "europe-west6"
bigquery_feature_table_id      = "forecast_features"
feast_online_store_location    = "europe-west6"
feast_online_store_database_name = "feast-online"
provision_cloud_run_service    = true
cloud_run_service_name         = "foehncast-serve"
cloud_run_image                = "europe-west6-docker.pkg.dev/your-gcp-project/foehncast-docker/foehncast-app:latest"
cloud_run_container_port       = 8080
cloud_run_allow_unauthenticated = true
cloud_run_min_instance_count   = 0
cloud_run_max_instance_count   = 2
cloud_run_cpu                  = "1"
cloud_run_memory               = "1Gi"
mlflow_tracking_uri            = "https://mlflow.example.com"
cloud_run_env_vars             = {}
provision_cloud_run_mlflow     = false
cloud_run_mlflow_service_name  = "foehncast-mlflow"
cloud_run_mlflow_image         = ""
cloud_sql_mlflow_instance_name = "foehncast-mlflow"
provision_cloud_workflows      = false
cloud_workflows_schedule       = "0 */6 * * *"
provision_cloud_run_ui         = false
cloud_run_ui_service_name      = "foehncast-ui"
cloud_run_ui_image             = ""
cloud_run_ui_prometheus_url    = ""  # GMP: https://monitoring.googleapis.com/v1/projects/PROJECT/location/global/prometheus
github_owner                   = "your-github-username"
github_repository              = "your-repo-name"
github_oidc_pool_id            = "github-actions"
github_oidc_provider_id        = "github-oidc"

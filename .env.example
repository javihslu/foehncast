# bootstrap-local.sh and bootstrap-gcp.sh create .env from this template.

# GCP
# Use gcloud ADC locally and GitHub OIDC in CI/CD. Do not commit service account keys.
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=europe-west6
GCP_BUCKET_NAME=foehncast-data
CLOUD_RUN_SERVICE_NAME=foehncast-serve
# Optional local key path. Leave empty when using Cloud Run identity or host ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Feature storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=data
STORAGE_S3_BUCKET=foehncast-data
STORAGE_S3_ENDPOINT=
STORAGE_BIGQUERY_PROJECT_ID=
STORAGE_BIGQUERY_DATASET=foehncast
STORAGE_BIGQUERY_TABLE=forecast_features

# Optional S3-compatible storage overrides
OBJECTSTORE_ACCESS_KEY=
OBJECTSTORE_SECRET_KEY=
OBJECTSTORE_ENDPOINT=

# MLflow
# Host tools use localhost; the development container uses http://model-registry:5001.
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_ARTIFACT_DESTINATION=file:///mlartifacts
MLFLOW_BIND_HOST=127.0.0.1

# Airflow
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW_CREATE_ADMIN_USER=false
AIRFLOW_BIND_HOST=127.0.0.1
AIRFLOW__WEBSERVER__CONFIG_FILE=/opt/airflow/webserver_config.py
# Airflow owns feature-pipeline orchestration inside the stack.
# Leave AIRFLOW_FEATURE_SCHEDULE empty, manual, or off to disable recurring refreshes.
AIRFLOW_FEATURE_DATASET=train
AIRFLOW_FEATURE_SCHEDULE=0 */6 * * *

# App
APP_BIND_HOST=127.0.0.1
FOEHNCAST_APP_IMAGE=foehncast-app:local
FOEHNCAST_AIRFLOW_IMAGE=foehncast-airflow:local
FOEHNCAST_MLFLOW_IMAGE=foehncast-mlflow:local

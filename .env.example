# bootstrap-local.sh and bootstrap-gcp.sh create .env from this template.

# GCP
# Use gcloud ADC locally and GitHub OIDC in CI/CD. Do not commit service account keys.
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=europe-west6
GCP_BUCKET_NAME=foehncast-data
CLOUD_RUN_SERVICE_NAME=foehncast-serve
# Optional local key path. Leave empty when using Cloud Run identity or host ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Curated feature storage
# These values are runtime wiring. The checked-in config.yaml keeps only the
# default storage mode; concrete resource names and endpoints come from env.
STORAGE_BACKEND=s3
STORAGE_S3_BUCKET=foehncast-data
STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
STORAGE_BIGQUERY_PROJECT_ID=
STORAGE_BIGQUERY_DATASET=foehncast
STORAGE_BIGQUERY_TABLE=forecast_features

# Local objectstore baseline for `./scripts/bootstrap-local.sh`.
# The bootstrap helper may move the host ports to the next free values when the
# preferred defaults are already in use.
OBJECTSTORE_BIND_HOST=127.0.0.1
OBJECTSTORE_PORT=9000
OBJECTSTORE_CONSOLE_PORT=9001
OBJECTSTORE_ACCESS_KEY=minioadmin
OBJECTSTORE_SECRET_KEY=minioadmin123
OBJECTSTORE_BUCKET=foehncast-data
OBJECTSTORE_ENDPOINT=

# MLflow
# This is runtime wiring. Host tools use localhost; the development container
# uses http://model-registry:5001.
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_ARTIFACT_DESTINATION=s3://foehncast-data/mlflow/artifacts
MLFLOW_BIND_HOST=127.0.0.1

# Airflow
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW_BIND_HOST=127.0.0.1
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_ALL_ADMINS=true
AIRFLOW__API_AUTH__JWT_SECRET=foehncast-local-jwt-secret
# Airflow owns feature-pipeline orchestration inside the stack.
# Leave AIRFLOW_FEATURE_SCHEDULE empty, manual, or off to disable recurring refreshes.
AIRFLOW_FEATURE_DATASET=train
AIRFLOW_FEATURE_SCHEDULE="0 */6 * * *"

# App
APP_BIND_HOST=127.0.0.1
FOEHNCAST_APP_IMAGE=foehncast-app:local
FOEHNCAST_AIRFLOW_IMAGE=foehncast-airflow:local
FOEHNCAST_MLFLOW_IMAGE=foehncast-mlflow:local

# Feast runtime binding
# Feast is the online-serving path in both local and hosted runtimes.
FOEHNCAST_FEAST_SOURCE=local
FOEHNCAST_FEAST_PROJECT=foehncast
FOEHNCAST_FEAST_LOCAL_DATASTORE_PROJECT_ID=foehncast-local
FOEHNCAST_FEAST_LOCAL_DATASTORE_NAMESPACE=
FOEHNCAST_FEAST_LOCAL_DATASTORE_DATABASE=
FEAST_DATASTORE_EMULATOR_BIND_HOST=127.0.0.1
FEAST_DATASTORE_EMULATOR_PORT=8181
# Leave blank to use the repo-local defaults for the bundled feature_repo and
# the rendered runtime config under .state/feast/.
FOEHNCAST_FEAST_REPO_PATH=
FOEHNCAST_FEAST_CONFIG_PATH=
FOEHNCAST_FEAST_REGISTRY=
# Cloud binding values are only required when FOEHNCAST_FEAST_SOURCE=bigquery.
FOEHNCAST_FEAST_PROJECT_ID=
FOEHNCAST_FEAST_GCS_BUCKET=
FOEHNCAST_FEAST_GCS_STAGING_LOCATION=
FOEHNCAST_FEAST_BIGQUERY_DATASET=feast
FOEHNCAST_FEAST_BIGQUERY_LOCATION=EU
FOEHNCAST_FEAST_BIGQUERY_TABLE=
FOEHNCAST_FEAST_DATASTORE_DATABASE=feast-online
FOEHNCAST_FEAST_DATASTORE_NAMESPACE=
